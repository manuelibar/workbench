# Workbench local development stack
# Copy to .env if you want Docker Compose and the MCP server to pick these up.

WORKBENCH_STORE_BACKEND=postgres
WORKBENCH_DATABASE_URL=postgres://workbench:workbench@localhost:5432/workbench?sslmode=disable
WORKBENCH_NATS_URL=nats://localhost:4222

WORKBENCH_POSTGRES_USER=workbench
WORKBENCH_POSTGRES_PASSWORD=workbench
WORKBENCH_POSTGRES_DB=workbench
WORKBENCH_POSTGRES_PORT=5432

WORKBENCH_NATS_PORT=4222
WORKBENCH_NATS_MONITOR_PORT=8222

# Optional MCP runtime configuration
# WORKBENCH_STORE=~/.workbench/projects.json
# WORKBENCH_PROJECT_ROOT=/path/to/project
# WORKBENCH_SKILLS_DIR=/path/to/skills
# WORKBENCH_GITHUB_ORG=
# WORKBENCH_GITHUB_TOKEN=
