# Copy to .env and adjust as needed; Makefile and direct `go run` will read
# from the process environment, not from this file. Use a tool like direnv,
# dotenv, or `set -a; source .env; set +a` to inject these into a shell.

# TCP bind address. Keep on 127.0.0.1 unless you know what you're doing — v0
# has no authentication.
WORKBENCH_BIND=127.0.0.1:7777

# Postgres DSN. Defaults match the docker-compose-managed instance.
WORKBENCH_DB_URL=postgres://workbench:workbench@127.0.0.1:5432/workbench?sslmode=disable

# Log level: debug, info, warn, or error.
WORKBENCH_LOG_LEVEL=info
