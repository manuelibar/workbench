# Copy to .env and adjust as needed. Workbench reads process environment only.

# Flat Markdown artifact directory.
WORKBENCH_ARTIFACT_DIR=docs/artifacts

# Capability relist wait after context changes. Accepts Go durations such as
# 5s, 250ms, or an integer number of seconds.
WORKBENCH_CONTEXT_SYNC_TIMEOUT=5s

# Log level: debug, info, warn, or error.
WORKBENCH_LOG_LEVEL=info
